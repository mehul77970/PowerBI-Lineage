{
  "name": "powerbi-lineage",
  "version": "0.5.2",
  "description": "Standalone Power BI lineage/usage dashboard — reads a .Report folder + .SemanticModel sibling, serves an interactive HTML dashboard.",
  "type": "module",
  "bin": {
    "powerbi-lineage": "dist/app.js"
  },
  "main": "dist/app.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/app.js",
    "dev": "tsc && node dist/app.js",
    "typecheck": "tsc --noEmit",
    "test": "tsc -p tsconfig.test.json && node scripts/run-tests.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  }
}
