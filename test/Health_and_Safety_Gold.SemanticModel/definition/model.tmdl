model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

/// Dimensional tables and reference data tables
queryGroup 'Dimension & Reference Tables'

	annotation PBI_QueryGroupOrder = 3

/// Fact tables for the current domain.
queryGroup 'Fact Tables'

	annotation PBI_QueryGroupOrder = 4

/// Group for storing parameters for domain connections
queryGroup 'Domain Connections'

	annotation PBI_QueryGroupOrder = 2

/// Contains conection parameters to the Global Data House GDH
queryGroup 'Global Data House Connections'

	annotation PBI_QueryGroupOrder = 1

queryGroup Tables

	annotation PBI_QueryGroupOrder = 0

/// Wave 3 related Dimensions and Fact tables
queryGroup 'Fact Tables\Pilot Wave'

	annotation PBI_QueryGroupOrder = 1

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_QueryOrder = ["dim_country","dim_group","dim_injury_type","dim_life_saving_rules","dim_serious_injury_fatality","dim_site","dim_workforce_category","fct_psif","fct_health_safety","Globa_Data_House","Global_Dimensions_Schema","Global_Data_House_SQL","Domain_Health_and_Safety_WH","Domain_Health_and_Safety_SQL","Domain_Health_and_Safety_Schema","fct_injuries","_Rollup_measures","dim_freetext_summary","Global_Dimensions_Text_Summary","table_PSIF","table_HS","table_injury","fct_trcf_targets","table_trcf_targets","Refresh Time Stamp"]

annotation PBI_ProTooling = ["DevMode","TMDLView_Desktop","MCP-PBIModeling"]

annotation __TEdtr = 1

ref table dim_country
ref table dim_group
ref table dim_injury_type
ref table dim_life_saving_rules
ref table dim_serious_injury_fatality
ref table dim_site
ref table dim_workforce_category
ref table fct_psif
ref table fct_health_safety
ref table fct_injuries
ref table Globa_Data_House
ref table Global_Dimensions_Schema
ref table Global_Data_House_SQL
ref table Domain_Health_and_Safety_WH
ref table Domain_Health_and_Safety_Schema
ref table Domain_Health_and_Safety_SQL
ref table _Rollup_measures
ref table dim_freetext_summary
ref table Global_Dimensions_Text_Summary
ref table table_PSIF
ref table table_HS
ref table table_injury
ref table fct_trcf_targets
ref table table_trcf_targets
ref table 'Refresh Time Stamp'

ref cultureInfo en-US

