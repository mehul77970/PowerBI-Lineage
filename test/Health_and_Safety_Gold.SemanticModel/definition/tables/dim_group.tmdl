		sourceColumn: sdp_created_date

		annotation SummarizationSetBy = Automatic

	column sdp_updated_date
		dataType: string
		isHidden
		lineageTag: c0e6a49c-3bec-4178-a078-247d7a056395
		summarizeBy: none
		sourceColumn: sdp_updated_date

		annotation SummarizationSetBy = Automatic

	column is_sdp_active
		dataType: boolean
		isHidden
		formatString: """TRUE"";""TRUE"";""FALSE"""
		lineageTag: b9d611a8-4714-4e33-9fce-cb307422a304
		summarizeBy: none
		sourceColumn: is_sdp_active

		annotation SummarizationSetBy = Automatic

	column sdp_effective_end_date
		dataType: int64
		isHidden
		formatString: 0
		lineageTag: e0c88d6b-4ad3-4db8-ba58-f11a65ab14ab
		summarizeBy: sum
		sourceColumn: sdp_effective_end_date

		annotation SummarizationSetBy = Automatic

	/// Sort order for group display.
	column order =
			SWITCH(TRUE(),
			dim_group[group_ID] = "G2" , 1,
			dim_group[group_ID] = "G3" , 2,
			dim_group[group_ID] = "G4" , 3,
			dim_group[group_ID] = "G5" , 4,
			dim_group[group_ID] = "G7" , 5,
			dim_group[group_ID] = "G6" , 6,
			dim_group[group_ID] = "G1" , 7,
			dim_group[group_ID] = "G0" , 0 )
		isHidden
		formatString: 0
		lineageTag: 6f310245-0872-4592-8af7-15466e8aa3bc
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	partition dim_group = m
		mode: import
		queryGroup: 'Dimension & Reference Tables'
		source =
				let
				    Source = Sql.Database(Global_Data_House_SQL, Globa_Data_House),
				    #"load" = Source{[Schema=Global_Dimensions_Schema,Item="dim_group"]}[Data],
				    #"Filtered Rows" = Table.SelectRows(load, each [is_sdp_active] = true)
				in
				    #"Filtered Rows"

	changedProperty = IsHidden

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

