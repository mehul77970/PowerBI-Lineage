	partition fct_health_safety = m
		mode: import
		queryGroup: 'Fact Tables\Pilot Wave'
		source =
				let
				    Source = Sql.Database(Domain_Health_and_Safety_SQL, Domain_Health_and_Safety_WH),
				    #"load" = Source{[Schema=Domain_Health_and_Safety_Schema,Item=table_HS]}[Data],
				    #"Changed Type" = Table.TransformColumnTypes(load,{{"number_worked_hours", type number}, {"number_fatal_injury", Int64.Type}, {"number_fatal_health", Int64.Type}}),
				    #"Rounded Off" = Table.TransformColumns(#"Changed Type",{{"number_worked_hours", each Number.Round(_, 2), type number}})
				in
