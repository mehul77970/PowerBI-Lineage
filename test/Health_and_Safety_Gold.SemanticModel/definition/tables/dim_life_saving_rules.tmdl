		isHidden
		lineageTag: 466e88a2-0652-4fbd-b44d-221d5cfb2eb2
		summarizeBy: none
		sourceColumn: sdp_pipeline_run_id

		annotation SummarizationSetBy = Automatic

	column sdp_group_filename
		dataType: string
		isHidden
		lineageTag: df75ca8f-b037-4337-8107-bd8726f2110d
		summarizeBy: none
		sourceColumn: sdp_group_filename

		annotation SummarizationSetBy = Automatic

	column sdp_load_date
		dataType: string
		isHidden
		lineageTag: 8a478358-a8be-4bf6-a935-5dcbf7b937e8
		summarizeBy: none
		sourceColumn: sdp_load_date

		annotation SummarizationSetBy = Automatic

	column sdp_created_date
		dataType: string
		isHidden
		lineageTag: 4e6fb7cc-b52a-49c6-9915-424f9e338bc7
		summarizeBy: none
		sourceColumn: sdp_created_date

