		annotation UnderlyingDateTimeDataType = Date

	partition dim_life_saving_rules = m
		mode: import
		queryGroup: 'Dimension & Reference Tables'
		source =
				let
				    Source = Sql.Database(Global_Data_House_SQL, Globa_Data_House),
				    Load = Source{[Schema=Global_Dimensions_Schema,Item="dim_life_saving_rules"]}[Data],
				        // Add "order" column
				    AddOrder = Table.AddColumn(
				        Load,
				        "order",
				        each if [life_saving_rules_ID] = "LSR0" then 1 else 0,
				        Int64.Type
				    ),
				    // Add "lsr_flag" column
				    AddFlag = Table.AddColumn(
				        AddOrder,
				        "lsr_flag",
				    each
				        if [life_saving_rules_ID] = "LSR00" then "Unknown"
				        else if [life_saving_rules_ID] = "LSR0" then "No"
				        else "Yes"
				    ),
				    #"Filtered Rows" = Table.SelectRows(AddFlag, each [is_sdp_active] = true)
				in
				    #"Filtered Rows"

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

