/// Dimension of Life Saving Rules (LSR) linked to groups, used to classify injuries by associated safety rule violations.
table dim_life_saving_rules
	lineageTag: f45fb972-857e-48ec-9ee6-ba46c3e19c69

	/// ID Identifying the LSR, connected to Group ID
	column life_saving_rules_ID
		dataType: string
		isHidden
		lineageTag: 591c7d72-54b8-459f-a384-5e2f3755e74b
		summarizeBy: none
		sourceColumn: life_saving_rules_ID

		annotation SummarizationSetBy = Automatic

	/// Type of the LSR
	column life_saving_rules_type
		dataType: string
		lineageTag: bd1c7e1b-7d28-4dd1-90f7-8df0d3fb6935
		summarizeBy: none
		sourceColumn: life_saving_rules_type

		changedProperty = SortByColumn

		annotation SummarizationSetBy = Automatic

	/// Name of the Group
	column group_name
		dataType: string
		lineageTag: 86a573da-f40d-41fa-ad0a-11f176dba19e
		summarizeBy: none
		sourceColumn: group_name

		annotation SummarizationSetBy = Automatic

	column order
		dataType: int64
		isHidden
		formatString: 0
		lineageTag: ea472893-f787-48e7-9bee-8f4455aa8ace
		summarizeBy: none
		sourceColumn: order

		annotation SummarizationSetBy = Automatic

	/// Flag indicating whether the LSR is active or applicable.
	column lsr_flag
		dataType: string
		lineageTag: 86c31c86-f5c2-4479-9f70-a9afce6f6dcd
		summarizeBy: none
		sourceColumn: lsr_flag

		annotation SummarizationSetBy = Automatic

