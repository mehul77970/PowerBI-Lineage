	column is_sdp_active
		dataType: boolean
		isHidden
		formatString: """TRUE"";""TRUE"";""FALSE"""
		lineageTag: 2dba3ce7-45fd-437c-aa71-4bbb3108b3f3
		summarizeBy: none
		sourceColumn: is_sdp_active

		annotation SummarizationSetBy = Automatic

	column sdp_effective_end_date
		dataType: dateTime
		isHidden
		formatString: Long Date
		lineageTag: 43d4efed-2a4b-4442-9519-b6248770cb15
		summarizeBy: none
