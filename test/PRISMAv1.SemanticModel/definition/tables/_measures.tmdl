	/// Net Revenue as a % of grand total, ignoring Category and Country filters. Use in category/country visuals to show revenue mix.
	measure 'Revenue % of Total' =
			DIVIDE(
			    [Net Revenue],
			    CALCULATE( [Net Revenue], ALL( Product[Category] ), ALL( Store[Country] ) )
			)
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: KPI - Sales
		lineageTag: 62a50780-9eb9-4e8b-8dcc-5be1c83e96b4

	/// Returns the country with the highest Net Revenue in the current filter context. Use in a card visual for executive narrative.
	measure 'Top Country' =
			CALCULATE(
			    SELECTEDVALUE( Store[Country] ),
			    TOPN( 1, ALL( Store[Country] ), [Net Revenue], DESC )
			)
		displayFolder: KPI - Sales
		lineageTag: daea6f30-ce54-4b0a-bbde-d9bdc1e9d87a

	/// Returns the product category with the highest Net Revenue in the current filter context. Use in a card visual for executive narrative.
	measure 'Top Category' =
			CALCULATE(
			    SELECTEDVALUE( Product[Category] ),
			    TOPN( 1, ALL( Product[Category] ), [Net Revenue], DESC )
			)
		displayFolder: KPI - Sales
		lineageTag: 48e9161a-552c-412d-8ca4-392b4808f1ad

	/// Dynamic Y-axis minimum for Margin % chart. Pads below the visible minimum by 50% of the visible range (min 0.5pp), then rounds down to the nearest 0.5pp. Use in a What-if parameter or axis min reference line.
	measure 'Margin % Axis Min' =
			VAR VisibleMin    = MINX( VALUES( 'Date'[Year Month Number] ), [Margin %] )
			VAR VisibleMax    = MAXX( VALUES( 'Date'[Year Month Number] ), [Margin %] )
			VAR VisibleRange  = VisibleMax - VisibleMin
			VAR Padding       = MAX( VisibleRange * 0.5, 0.005 )  -- at least 0.5pp padding each side
			RETURN
			    FLOOR( ( VisibleMin - Padding ) * 100, 0.5 ) / 100
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Formatting - Examples
		lineageTag: 16a42d36-6622-455a-9708-1a621e589ce2

	/// Dynamic Y-axis maximum for Margin % chart. Pads above the visible maximum by 50% of the visible range (min 0.5pp), then rounds up to the nearest 0.5pp. Use in a What-if parameter or axis max reference line.
	measure 'Margin % Axis Max' =
			VAR VisibleMin    = MINX( VALUES( 'Date'[Year Month Number] ), [Margin %] )
			VAR VisibleMax    = MAXX( VALUES( 'Date'[Year Month Number] ), [Margin %] )
			VAR VisibleRange  = VisibleMax - VisibleMin
			VAR Padding       = MAX( VisibleRange * 0.5, 0.005 )  -- at least 0.5pp padding each side
			RETURN
			    CEILING( ( VisibleMax + Padding ) * 100, 0.5 ) / 100
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Formatting - Examples
		lineageTag: d406af72-94d6-4ad4-9c03-9d889e4a9701

