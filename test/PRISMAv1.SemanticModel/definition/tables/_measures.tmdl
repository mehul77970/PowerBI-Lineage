	/// RAG trend arrow for Revenue per Store (Open) vs SPLY.
	measure 'Revenue per Store Arrow' = udf.adaptfy.svg.ragArrow( [Revenue per Store Delta %], "NORMAL", 48, "ARROW" )
		displayFolder: Formatting - Examples
