		formatString: #,0
		displayFolder: Product
		lineageTag: f5ee2e74-3a83-4f58-9172-a2f8f3775f5a

	/// Average realised net revenue per unit sold: DIVIDE([Net Revenue], [Units Sold]).
	measure 'Avg Unit Price' =
			
