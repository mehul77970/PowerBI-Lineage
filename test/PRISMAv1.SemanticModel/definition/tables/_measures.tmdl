	/// RAG trend arrow for Revenue per Product vs SPLY.
	measure 'Revenue per Product Arrow' = udf.adaptfy.svg.ragArrow( [Revenue per Product Delta %], "NORMAL", 48, "ARROW" )
		displayFolder: Formatting - Examples
		lineageTag: 8596545f-5b41-426e-a737-5d6c37e089cc
		dataCategory: ImageUrl

	/// Returns the brand with the highest Net Revenue in the current filter context.
	measure 'Top Brand' =
			CALCULATE(
			    SELECTEDVALUE( Product[Brand] ),
			    TOPN( 1, ALL( Product[Brand] ), [Net Revenue], DESC )
			)
		displayFolder: Product
		lineageTag: a454a986-68f7-427b-978c-f6eea665c28f

	/// RAG trend arrow for Discount Delta pp vs SPLY. Delta is rounded to 2dp before passing to UDF so sub-0.01pp changes render as amber neutral rather than triggering a red/green arrow. INVERSE direction — red when discounting increases, green when it decreases.
	measure 'Discount Arrow' =
			VAR RawDelta    = [Discount Delta pp]
			VAR RoundedDelta = ROUND( RawDelta, 2 )
			RETURN
			    udf.adaptfy.svg.ragArrow( RoundedDelta, "INVERSE", 48, "ARROW" )
		displayFolder: Formatting - Examples
		lineageTag: 9853dfb7-9b3e-4f2a-83ff-58d2f516ca7d
		dataCategory: ImageUrl

	/// Customers whose first ever order falls within the current filter context period.
	measure 'New Customers' =
			CALCULATE(
			    DISTINCTCOUNT( Sales[CustomerKey] ),
			    FILTER(
			        VALUES( Sales[CustomerKey] ),
			        VAR FirstPurchaseDate =
			            CALCULATE( MIN( Sales[Order Date] ), ALL( 'Date' ) )
			        RETURN
			            FirstPurchaseDate >= MIN( 'Date'[Date] ) &&
			            FirstPurchaseDate <= MAX( 'Date'[Date] )
			    )
			)
		formatString: #,0
		displayFolder: Customer
		lineageTag: 1a3bc347-9f57-45f2-afd7-d401f627cfbe

	/// Customers who made their first purchase before the current filter period.
	measure 'Returning Customers' =
			CALCULATE(
			    DISTINCTCOUNT( Sales[CustomerKey] ),
			    FILTER(
			        VALUES( Sales[CustomerKey] ),
			        VAR FirstPurchaseDate =
			            CALCULATE( MIN( Sales[Order Date] ), ALL( 'Date' ) )
			        RETURN
			            FirstPurchaseDate < MIN( 'Date'[Date] )
			    )
			)
		formatString: #,0
		displayFolder: Customer
		lineageTag: aebaa99d-b1ea-436e-87af-1e0f765509c8

	/// Share of active customers in the period who are buying for the first time.
	measure 'New Customer %' = DIVIDE( [New Customers], [Customers] )
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Customer
		lineageTag: c4b83ce5-e8d8-458f-b116-7a8e75f759a9

