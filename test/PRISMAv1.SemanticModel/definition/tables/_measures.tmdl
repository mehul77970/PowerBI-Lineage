		lineageTag: a88ee692-370b-4fe3-86ba-e05f8b44d831

	/// Count of permanently closed stores. Excludes Restructured.
	measure 'Closed Stores' = CALCULATE( DISTINCTCOUNT( Store[Store Code] ), Store[Store Status] = "Closed" )
		formatString: #,0
		displayFolder: Geography
		lineageTag: e37ee5c3-656b-48e5-9e7f-1f2d1a30f8da

	/// Average Store[Square Meters] across the current selection.
	measure 'Avg Sq Meters' =
			
			AVERAGE( Store[Square Meters] )
		formatString: #,0.0
		displayFolder: Geography
		lineageTag: d3bd467f-a518-48c0-9313-cc80b55feca4

	/// Average Net Revenue per open physical store. Excludes Online channel from both numerator and denominator.
	measure 'Revenue per Store' =
			DIVIDE(
			    [Physical Revenue],
			    CALCULATE( DISTINCTCOUNT( Store[Store Code] )
			))
		formatString: #,0
		displayFolder: Geography
		lineageTag: 49b67028-fefb-433e-913b-c5d8af71372f

	/// Physical Net Revenue per square metre of active physical floor space. Excludes Online channel from both numerator and denominator.
	measure 'Revenue per Sq Meter' =
			DIVIDE(
			    [Physical Revenue],
			    CALCULATE( SUM( Store[Square Meters] )
			))
		formatString: #,0.00
		displayFolder: Geography
		lineageTag: 1dcbc75e-a72e-4d40-b8d0-52f663438d80

	/// Net revenue converted to USD using row‑level Sales[Exchange Rate].
	measure 'Sales Amount USD' =
			
			SUMX(
			    Sales,
			    Sales[Quantity] * Sales[Net Price] * Sales[Exchange Rate]
			)
		formatString: #,0
		isHidden
		displayFolder: Currency
		lineageTag: 849c3fc0-539d-4ff3-a180-8f36a8fe79be

		changedProperty = IsHidden

	/// Gross margin dollars for Same Period Last Year.
	measure 'Net Profit SPLY' =
			VAR _AllSelected = COUNTROWS( 'Date' ) = CALCULATE( COUNTROWS( 'Date' ), ALL( 'Date' ) )
			RETURN IF( _AllSelected, BLANK(), udf.adaptfy.timeintellgence( [Net Profit], 'Date'[Date], "SPLY" ) )
		formatString: #,0
		displayFolder: KPI - Time Intelligence
		lineageTag: 95c1be3d-f3ea-4213-adf1-9dc337209127

	/// Net profit margin % for Same Period Last Year.
	measure 'Margin % SPLY' =
			VAR _AllSelected = COUNTROWS( 'Date' ) = CALCULATE( COUNTROWS( 'Date' ), ALL( 'Date' ) )
			RETURN IF( _AllSelected, BLANK(), udf.adaptfy.timeintellgence( [Margin %], 'Date'[Date], "SPLY" ) )
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: KPI - Time Intelligence
		lineageTag: 1c5116c2-2c5f-41ca-a32a-82eb6cd3eb5d

	/// Change in net profit margin % vs Same Period Last Year, expressed in percentage points.
	measure 'Margin Delta pp' =
			VAR _TotalDates  = CALCULATE( COUNTROWS( 'Date' ), ALL( 'Date' ) )
			VAR _AllSelected = COUNTROWS( 'Date' ) = _TotalDates
			VAR MarginNow    = [Margin %]
			VAR MarginPrior  = udf.adaptfy.timeintellgence( [Margin %], 'Date'[Date], "SPLY" )
			RETURN
			    IF(
			        _AllSelected,
			        0,
			        IF(
			            NOT ISBLANK( MarginNow ) && NOT ISBLANK( MarginPrior ),
			            ( MarginNow - MarginPrior ) * 100
			        )
			    )
		formatString: 0.00 "pp";-0.00 "pp";0.00 "pp"
		displayFolder: KPI - Time Intelligence
		lineageTag: 7fb52cfa-0ecd-4600-945e-faff4215cbb4

		annotation PBI_FormatHint = {"isCustom":true}

