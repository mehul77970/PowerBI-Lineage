table _measures
	lineageTag: 9452c871-433c-4553-9ec0-1fd4c4b98b20

	/// Count of stores with Store Status = Open in the current filter context.
	measure 'Active Stores' = CALCULATE( DISTINCTCOUNT( Store[Store Code] ), Store[Store Status] = "Open" )
		formatString: #,0
		displayFolder: Geography
		lineageTag: faf2c38b-5fbf-4fd9-8e8b-d709cf5c6cc4

	/// Revenue at list price: SUMX of Sales[Quantity] * Sales[Unit Price].
	measure 'Gross Revenue' =
			
			SUMX( Sales, Sales[Quantity] * Sales[Unit Price] )
		formatString: #,0
		displayFolder: KPI - Sales
		lineageTag: 3864f6ec-b4b3-490c-9438-ea79216f1524

	/// Average net revenue per order: DIVIDE([Net Revenue], [Orders]).
	measure 'Avg Order Value' =
			
			DIVIDE( [Net Revenue], [Orders] )
		formatString: #,0
		displayFolder: KPI - Sales
		lineageTag: 2b253de4-d5c1-4ff6-a346-402f12dfe2cd

	/// Number of unique order lines: COUNTROWS over distinct combinations of Order Number and Line Number.
	measure 'Line Items' =
			
			VAR Lines =
			    SUMMARIZE( Sales, Sales[Order Number], Sales[Line Number] )
			RETURN
			    COUNTROWS( Lines )
		formatString: #,0
		displayFolder: KPI - Sales
		lineageTag: a4844a3d-9c34-4559-baff-02afad5837e3

	/// Average lines per order: DIVIDE([Total Line Items],[Total Orders]).
	measure 'Avg Line Items' =
			
			DIVIDE( [Line Items], [Orders] )
		formatString: #,0.0
		displayFolder: KPI - Sales
		lineageTag: e005c246-045e-4973-b668-58256212399e

	/// Distinct orders for Same Period Last Year, based on Date[Date].
	measure 'Orders SPLY' =
			VAR _AllSelected = COUNTROWS( 'Date' ) = CALCULATE( COUNTROWS( 'Date' ), ALL( 'Date' ) )
			RETURN IF( _AllSelected, BLANK(), udf.adaptfy.timeintellgence( [Orders], 'Date'[Date], "SPLY" ) )
		formatString: #,0
		displayFolder: KPI - Time Intelligence
		lineageTag: 24115dae-b5ea-42af-900c-381d7ea38ab4

	/// Absolute change in Orders vs Same Period Last Year.
	measure 'Orders Delta' =
			VAR _TotalDates    = CALCULATE( COUNTROWS( 'Date' ), ALL( 'Date' ) )
			VAR _AllSelected   = COUNTROWS( 'Date' ) = _TotalDates
			RETURN IF( _AllSelected, 0, udf.adaptfy.timeintellgence( [Orders], 'Date'[Date], "DELTA" ) )
		formatString: #,0
		displayFolder: KPI - Time Intelligence
		lineageTag: 20d3e1e7-6a17-4882-bf35-b7c554d99a6f

	/// Percent change in orders vs Same Period Last Year.
	measure 'Orders Delta %' =
			VAR _TotalDates    = CALCULATE( COUNTROWS( 'Date' ), ALL( 'Date' ) )
			VAR _AllSelected   = COUNTROWS( 'Date' ) = _TotalDates
			RETURN IF( _AllSelected, 0, udf.adaptfy.timeintellgence( [Orders], 'Date'[Date], "PCT" ) )
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: KPI - Time Intelligence
		lineageTag: f8005450-11bc-4b89-849a-293596b0523b

	/// Average Order Value for Same Period Last Year.
