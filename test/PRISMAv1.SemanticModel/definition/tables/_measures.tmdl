	/// Discount rate for Same Period Last Year.
	measure 'Discount % SPLY' =
			VAR _AllSelected = COUNTROWS( 'Date' ) = CALCULATE( COUNTROWS( 'Date' ), ALL( 'Date' ) )
			RETURN IF( _AllSelected, BLANK(), udf.adaptfy.timeintellgence( [Discount %], 'Date'[Date], "SPLY" ) )
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Product
		lineageTag: a8508f7b-92fe-4fe0-bd5f-6d74305ac2db

	/// Change in discount rate vs Same Period Last Year in percentage points. Positive = discounting more.
	measure 'Discount Delta pp' =
			VAR _TotalDates    = CALCULATE( COUNTROWS( 'Date' ), ALL( 'Date' ) )
			VAR _AllSelected   = COUNTROWS( 'Date' ) = _TotalDates
			VAR DiscountNow    = [Discount %]
			VAR DiscountPrior  = udf.adaptfy.timeintellgence( [Discount %], 'Date'[Date], "SPLY" )
			RETURN
			    IF(
			        _AllSelected,
			        0,
			        IF(
			            NOT ISBLANK( DiscountNow ) && NOT ISBLANK( DiscountPrior ),
			            ( DiscountNow - DiscountPrior ) * 100
			        )
			    )
		formatString: 0.00 "pp";-0.00 "pp";0.00 "pp"
		displayFolder: Product
		lineageTag: 0921ea12-7cda-4aa1-ac67-bad752431a92

	/// Average Net Revenue per unique product. Measures portfolio revenue efficiency.
	measure 'Revenue per Product' = DIVIDE( [Net Revenue], [Unique Products] )
		formatString: #,0
		displayFolder: Product
		lineageTag: 17e2cf0b-34ee-4d3e-8455-4991dc124ece

