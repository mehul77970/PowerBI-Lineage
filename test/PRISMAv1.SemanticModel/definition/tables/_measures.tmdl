		lineageTag: 974dca14-bcf7-4135-bff0-d454a9de6ab9
		dataCategory: ImageUrl

	/// RAG trend arrow for Physical Revenue vs SPLY.
	measure 'Physical Revenue Arrow' = udf.adaptfy.svg.ragArrow( [Physical Revenue Delta %], "NORMAL", 48, "ARROW" )
		displayFolder: Formatting - Examples
		lineageTag: 627ed6bf-66cf-453a-8932-0fab34df3940
		dataCategory: ImageUrl

	/// Dynamic text banner showing active store counts by channel. Recalculates automatically if store data changes. Use in a Card visual as a compact header on the store page.
	measure 'Store Summary Banner' =
			VAR PhysicalOpen = CALCULATE( DISTINCTCOUNT( Store[Store Code] ), Store[Channel] = "Physical", Store[Store Status] = "Open" )
			VAR OnlineOpen   = CALCULATE( DISTINCTCOUNT( Store[Store Code] ), Store[Channel] = "Online",   Store[Store Status] = "Open" )
			RETURN
			    FORMAT( PhysicalOpen, "0" ) & " physical stores  ·  " &
			    FORMAT( OnlineOpen,   "0" ) & " online store"
		displayFolder: Formatting - Examples
		lineageTag: 836eb567-526d-4645-88e0-0e5f88d26583

	/// Online channel share of Net Revenue for Same Period Last Year.
	measure 'Online Share SPLY' =
			VAR _AllSelected = COUNTROWS( 'Date' ) = CALCULATE( COUNTROWS( 'Date' ), ALL( 'Date' ) )
			RETURN IF( _AllSelected, BLANK(), udf.adaptfy.timeintellgence( [Online vs Physical %], 'Date'[Date], "SPLY" ) )
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Geography
		lineageTag: dd34c386-2f72-4260-b7cc-e1725dcaead0

	/// Change in Online channel revenue share vs Same Period Last Year, expressed in percentage points. Uses udf.adaptfy.timeintellgence for SPLY calculation.
	measure 'Online Share Delta pp' =
			VAR _TotalDates    = CALCULATE( COUNTROWS( 'Date' ), ALL( 'Date' ) )
			VAR _AllSelected   = COUNTROWS( 'Date' ) = _TotalDates
			VAR OnlinePctNow   = [Online vs Physical %]
			VAR OnlinePctPrior = udf.adaptfy.timeintellgence( [Online vs Physical %], 'Date'[Date], "SPLY" )
			RETURN
			    IF(
			        _AllSelected,
			        0,
			        IF(
			            NOT ISBLANK( OnlinePctNow ) && NOT ISBLANK( OnlinePctPrior ),
			            ( OnlinePctNow - OnlinePctPrior ) * 100
			        )
			    )
		formatString: 0.00 "pp";-0.00 "pp";0.00 "pp"
		displayFolder: Geography
		lineageTag: 56e1b707-66e3-42e9-af71-0f72a050397a

	/// RAG trend arrow for Online Share Delta pp vs SPLY.
	measure 'Online Share Arrow' = udf.adaptfy.svg.ragArrow( [Online Share Delta pp], "NORMAL", 48, "ARROW" )
		displayFolder: Formatting - Examples
		lineageTag: 65820d5c-441c-46cc-b1b1-876ff630913e
		dataCategory: ImageUrl

