	/// Revenue per square metre for Same Period Last Year.
	measure 'Revenue per Sq Meter SPLY' =
			VAR _AllSelected = COUNTROWS( 'Date' ) = CALCULATE( COUNTROWS( 'Date' ), ALL( 'Date' ) )
			RETURN IF( _AllSelected, BLANK(), udf.adaptfy.timeintellgence( [Revenue per Sq Meter], 'Date'[Date], "SPLY" ) )
		formatString: #,0.00
		displayFolder: Geography
		lineageTag: 6eb5ca64-0938-4754-8b2b-39fe454f3465

	/// Percent change in revenue per square metre vs Same Period Last Year.
	measure 'Revenue per Sq Meter Delta %' =
			VAR _TotalDates    = CALCULATE( COUNTROWS( 'Date' ), ALL( 'Date' ) )
			VAR _AllSelected   = COUNTROWS( 'Date' ) = _TotalDates
			RETURN IF( _AllSelected, 0, udf.adaptfy.timeintellgence( [Revenue per Sq Meter], 'Date'[Date], "PCT" ) )
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Geography
		lineageTag: 7d35872b-d61f-4e58-912a-72a4d7ab94fd

	/// Online channel share of total Net Revenue.
	measure 'Online vs Physical %' =
			DIVIDE(
			    CALCULATE( [Net Revenue], Store[Channel] = "Online" ),
			    [Net Revenue]
			)
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Geography
		lineageTag: 5daa8fa7-51ba-4fab-8981-b36147227a3b

	/// Net Revenue from physical stores only, excluding Online.
	measure 'Physical Revenue' = CALCULATE( [Net Revenue], Store[Channel] = "Physical" )
		formatString: #,0
		displayFolder: Geography
		lineageTag: ab484a54-5cc3-4f90-9786-8f97c461c573

	/// Net Revenue from the Online channel.
	measure 'Online Revenue' = CALCULATE( [Net Revenue], Store[Channel] = "Online" )
		formatString: #,0
		displayFolder: Geography
		lineageTag: 1e6c25ea-db50-4e01-b3e9-1fd53d8a8f16

	/// Average floor area (sqm) across active physical stores only. Excludes Online and closed/restructured stores.
	measure 'Avg Store Size' =
			CALCULATE(
			    AVERAGE( Store[Square Meters] ),
			    Store[Store Status] = "Open",
			    Store[Channel] = "Physical"
			)
		formatString: #,0.0
		displayFolder: Geography
		lineageTag: 8c34f16e-9c08-4bcc-b0d2-4480e6a65da1

	/// Share of stores permanently closed: Closed Stores / Total Stores.
	measure 'Store Closure Rate' = DIVIDE( [Closed Stores], [Stores] )
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Geography
		lineageTag: a35ecd9c-44bd-4a35-988a-665e902a6c4c

	/// Online channel Net Revenue for Same Period Last Year.
