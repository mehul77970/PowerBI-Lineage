	/// Distinct count of customers with activity in the current filter context.
	measure Customers =
			
			DISTINCTCOUNT( Customer[CustomerKey] )
		formatString: #,0
		displayFolder: Customer
		lineageTag: 31d810bc-e553-408e-81a7-700cf58a780e

	/// Average age (in years) of customers in the current filter context.
	measure 'Average Age' =
			
			AVERAGE( Customer[Age] )
		formatString: #,0.0
		displayFolder: Customer
		lineageTag: 8fa88e1c-5e1a-4543-b5fd-eca08708718f

	/// Average Net Revenue per active customer in the current filter context. Uses customers who actually transacted in the period, not all-time distinct customers.
	measure 'Revenue per Customer' = DIVIDE( [Net Revenue], DISTINCTCOUNT( Sales[CustomerKey] ) )
		formatString: #,0
		displayFolder: Customer
		lineageTag: 47983de3-d642-49c7-a2ef-fca38e95da06

	/// Share of customers with two or more distinct orders: customers with ≥2 orders divided by all active customers.
	measure 'Repeat Rate' =
			
			VAR T =
			    SUMMARIZE(
			        Sales,
			        Sales[CustomerKey],
			        "Orders", DISTINCTCOUNT( Sales[Order Number] )
			    )
			RETURN
			    DIVIDE(
			        COUNTROWS( FILTER( T, [Orders] >= 2 ) ),
			        COUNTROWS( T )
			    )
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Customer
		lineageTag: 1bcdbf15-9f52-4285-98c4-f7364015a2bb

	/// Distinct count of Product[ProductKey] in filter context (products available/sold).
	measure 'Unique Products' =
			
			DISTINCTCOUNT( Product[ProductKey] )
		formatString: #,0
		displayFolder: Product
		lineageTag: ae73af14-1585-4b5d-a5ea-71cd33bc1ac0

	/// Distinct count of Product[Brand] in filter context.
	measure 'Active Brands' =
			
