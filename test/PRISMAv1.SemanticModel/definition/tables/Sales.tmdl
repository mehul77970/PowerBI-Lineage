		annotation SummarizationSetBy = Automatic

	/// Foreign key to the Product dimension table.
	column ProductKey
		dataType: int64
		isHidden
		formatString: 0
		lineageTag: f011ea83-0d14-41e5-a9f2-8d532338586f
		summarizeBy: none
		sourceColumn: ProductKey

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

	/// Number of units sold on this order line.
	column Quantity
		dataType: int64
		isHidden
		formatString: 0
		lineageTag: c8ca10d3-f54d-4c5d-b5ef-da854e2d7973
		summarizeBy: none
		sourceColumn: Quantity

		changedProperty = IsHidden

		annotation SummarizationSetBy = User

	/// Unique identifier for a sales order. Multiple lines share the same Order Number.
	column 'Order Number'
		dataType: int64
		isHidden
		formatString: 0
		lineageTag: 27170f5b-39b9-494d-b77c-00606c248f2a
		summarizeBy: count
		sourceColumn: Order Number

		annotation SummarizationSetBy = Automatic

	/// Line item number within an order. Combined with Order Number uniquely identifies a transaction row.
	column 'Line Number'
		dataType: int64
		isHidden
		formatString: 0
		lineageTag: 9ac9e454-4919-4492-a489-e38b38bf4f66
		summarizeBy: sum
		sourceColumn: Line Number

		annotation SummarizationSetBy = Automatic

	/// Date the order was placed. Used as the active date relationship to the Date table.
	column 'Order Date'
		dataType: dateTime
		isHidden
		formatString: General Date
		lineageTag: 54dfa354-027f-4264-a9c9-1e0213db865a
		summarizeBy: none
		sourceColumn: Order Date

		annotation SummarizationSetBy = Automatic

	/// Date the order was delivered. Linked to the Date table via an inactive relationship.
	column 'Delivery Date'
		dataType: dateTime
		isHidden
		formatString: General Date
		lineageTag: bfeebab9-451b-4816-91a6-0ee922c0d76b
		summarizeBy: none
		sourceColumn: Delivery Date

		annotation SummarizationSetBy = Automatic

	/// List price per unit at the time of sale (before discounts).
	column 'Unit Price'
		dataType: decimal
		isHidden
		lineageTag: d3301ed0-8b99-46c0-9555-ed28b4ed00f4
		summarizeBy: sum
		sourceColumn: Unit Price

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Actual selling price per unit after discounts. Used to calculate Sales Amount.
	column 'Net Price'
		dataType: decimal
		isHidden
		lineageTag: 0601f915-bc0f-4432-a24c-39fe79cfcd82
		summarizeBy: sum
		sourceColumn: Net Price

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Cost of goods per unit. Used to calculate Total Cost and Margin.
	column 'Unit Cost'
		dataType: decimal
		isHidden
		lineageTag: f8f202f4-dbdb-423c-b75e-c2f5f9ed3723
		summarizeBy: sum
		sourceColumn: Unit Cost

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// ISO currency code for the transaction (e.g. USD, EUR). Links to Currency Exchange for conversion.
	column 'Currency Code'
		dataType: string
		isHidden
		lineageTag: cabc3fde-bb38-40c8-b889-4a3314775037
		summarizeBy: none
		sourceColumn: Currency Code

		annotation SummarizationSetBy = Automatic

	/// FX rate at time of sale, used to convert Net Price to USD.
	column 'Exchange Rate'
		dataType: double
		isHidden
		lineageTag: d7719257-3b11-442e-a071-4540b1855e5b
		summarizeBy: sum
		sourceColumn: Exchange Rate

		annotation SummarizationSetBy = Automatic

