/// Central fact table. One row per order line. Transactional data with quantities, prices, costs, dates, and FK keys to all dimensions.
table Sales
	lineageTag: 94d3ea3b-4449-4e27-903d-c961f1df5413

	/// Net revenue from sales: SUMX of Sales[Quantity] * Sales[Net Price] in current filter context.
	measure 'Net Revenue' =
			
			SUMX( Sales, Sales[Quantity] * Sales[Net Price] )
		formatString: #,0
		lineageTag: 7c5f9a14-3465-43ab-b1e5-aeb03f4fe8ad

		changedProperty = FormatString

	/// Total cost of goods sold: SUMX of Sales[Quantity] * Sales[Unit Cost] in current filter context.
	measure Cost =
			
			SUMX( Sales, Sales[Quantity] * Sales[Unit Cost] )
		formatString: #,0
		lineageTag: 416604ca-8ec2-48fb-97e3-568ef1a0c264

		changedProperty = FormatString

	/// Net profit in absolute value: Net Revenue minus Cost. As COGS is the only expense in this model this represents the net profit.
	measure 'Net Profit' =
			
			[Net Revenue] - [Cost]
		formatString: #,0
		lineageTag: e22dbc08-3844-485a-96d6-625d9d77e004

		changedProperty = FormatString

	/// Total units sold: SUM of Sales[Quantity] in current filter context.
	measure 'Units Sold' =
			
			SUM( Sales[Quantity] )
		formatString: #,0
		lineageTag: 3c59d762-8e5b-4258-a132-1b6983b435ce

		changedProperty = FormatString

	/// Distinct count of orders in the current filter context.
	measure Orders =
			
			DISTINCTCOUNT( Sales[Order Number] )
		formatString: #,0
		lineageTag: 4de0ade3-e121-4f05-a5d2-907ec49411a5

	/// Net profit margin %: DIVIDE([Net Profit], [Net Revenue]). Represents the share of net revenue retained as profit after deducting cost of goods.
	measure 'Margin %' =
			
			DIVIDE( [Net Profit], [Net Revenue] )
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 78f2291d-1076-4202-b7bc-8d5dcd28f612

		changedProperty = FormatString

	/// Foreign key to the Customer dimension table.
	column CustomerKey
		dataType: int64
		isHidden
		formatString: 0
		lineageTag: b35afdc7-615a-4e88-8c36-36c10285f310
		summarizeBy: none
		sourceColumn: CustomerKey

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

	/// Foreign key to the Store dimension table.
	column StoreKey
		dataType: int64
		isHidden
		formatString: 0
		lineageTag: f917bacb-2013-409d-9d94-8b40068bc9a7
		summarizeBy: none
		sourceColumn: StoreKey

