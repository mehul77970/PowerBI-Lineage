	partition Sales-4929449f-be0b-48cf-a44e-c644698415ba = m
		mode: import
		source =
				let
				    Source = Parquet.Document(File.Contents("C:\Users\JonathanPapworth\Downloads\parquet-1m\sales.parquet")),
				    #"Renamed Columns" = Table.RenameColumns(Source, {
				        {"OrderKey", "Order Number"},
				        {"LineNumber", "Line Number"},
				        {"OrderDate", "Order Date"},
				        {"DeliveryDate", "Delivery Date"},
				        {"UnitPrice", "Unit Price"},
				        {"NetPrice", "Net Price"},
				        {"UnitCost", "Unit Cost"},
				        {"CurrencyCode", "Currency Code"},
				        {"ExchangeRate", "Exchange Rate"}
				    }),
				    #"Selected Columns" = Table.SelectColumns(#"Renamed Columns", {"Order Number", "Line Number", "Order Date", "Delivery Date", "CustomerKey", "StoreKey", "ProductKey", "Quantity", "Unit Price", "Net Price", "Unit Cost", "Currency Code", "Exchange Rate"}),
				    #"Changed Type" = Table.TransformColumnTypes(#"Selected Columns", {{"Unit Price", Currency.Type}, {"Net Price", Currency.Type}, {"Unit Cost", Currency.Type}}),
				        #"Updated Year" = Table.TransformColumns(#"Changed Type", {{"Order Date", each if Date.Year(_) = 2016 then Date.AddYears(_, 10) else _, type datetimezone}}), #"Drop 2026 bad months" = Table.SelectRows(#"Updated Year", each
				        let d = DateTime.Date(DateTimeZone.RemoveZone([Order Date])), y = Date.Year(d), m = Date.Month(d)
				        in y <> 2026 or List.Contains({7,8,9,10}, m)),    #"Shift 2026 to YTD" = Table.TransformColumns(#"Drop 2026 bad months", {
				        {"Order Date", each if Date.Year(DateTime.Date(DateTimeZone.RemoveZone(_))) = 2026 then DateTimeZone.From(Date.AddMonths(DateTime.Date(DateTimeZone.RemoveZone(_)), -6)) else _, type datetimezone},
				        {"Delivery Date", each if _ <> null and Date.Year(DateTime.Date(DateTimeZone.RemoveZone(_))) = 2026 then DateTimeZone.From(Date.AddMonths(DateTime.Date(DateTimeZone.RemoveZone(_)), -6)) else _, type datetimezone}
				    })
				in
				    #"Shift 2026 to YTD"

	annotation PBI_ResultType = Table

	annotation PBI_NavigationStepName = Navigation

