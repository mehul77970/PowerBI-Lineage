/// Product dimension. One row per product. Full catalogue with category/subcategory hierarchy, pricing, and physical attributes.
table Product
	lineageTag: 788e06ac-419f-4210-be7d-232115f91c18

	/// Primary key uniquely identifying each product.
	column ProductKey
