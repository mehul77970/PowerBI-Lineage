		/// Lowest level. Product subcategory within the selected category.
		level Subcategory
			lineageTag: 795213b8-537b-4217-8fa2-6e75719bbea4
			column: Subcategory

	partition Product-9730db17-a88f-43ad-b6f2-50ae8a679b18 = m
