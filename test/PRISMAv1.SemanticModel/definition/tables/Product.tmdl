		summarizeBy: none
		sourceColumn: ProductKey

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

	/// Company that manufactures the product.
	column Manufacturer
		dataType: string
		lineageTag: 06d0bedb-8e42-4069-b7d7-6273e4eaac2b
		summarizeBy: none
		sourceColumn: Manufacturer

