		    "🖋️  Signature:"                                & LineBreak &
		    "   udf.adaptfy.timeintellgence("              & LineBreak &
		    "       BaseMeasure  : ANYREF EXPR,"           & LineBreak &
		    "       DateColumn   : ANYREF EXPR,"           & LineBreak &
		    "       Outcome      : STRING"                 & LineBreak &
		    "   )"                                         & LineBreak &
		    LineBreak &
		    "📋 Outcome values:"                            & LineBreak &
		    "   SPLY             → Same Period Last Year"  & LineBreak &
		    "   DELTA / SPLY_DELTA → Absolute change"     & LineBreak &
		    "   PCT / SPLY% / SPLY-PCT → % change"        & LineBreak &
		    LineBreak &
		    "⚠️  Usage notes:"                              & LineBreak &
