/// Returns usage documentation for the udf.adaptfy.svg.ragArrow function.
function 'udf.adaptfy.svg.ragArrow.About' =
		() =>
		VAR LineBreak = UNICHAR ( 10 )
		RETURN
		    "💡 Library:   udf.adaptfy.svg"                   & LineBreak &
		    "🧑 Author:    Adaptfy"                             & LineBreak &
		    "📦 Version:   0.2.0"                               & LineBreak &
		    "⚖️  License:   Unspecified"                          & LineBreak &
		    LineBreak &
		    "🖋️  Signature:"                                    & LineBreak &
		    "   udf.adaptfy.svg.ragArrow("                      & LineBreak &
		    "       BaseMeasure  : ANYREF EXPR,"                & LineBreak &
		    "       Direction    : STRING,"                     & LineBreak &
		    "       SizePx       : DOUBLE,"                     & LineBreak &
		    "       Style        : STRING"                      & LineBreak &
		    "   )"                                              & LineBreak &
		    LineBreak &
		    "🎨 Returns:   SVG data URI"                        & LineBreak &
		    "   ↗️  Green  UP      → positive (normal)"          & LineBreak &
		    "   ↘️  Red    DOWN    → negative (normal)"          & LineBreak &
		    "   —  Amber  NEUTRAL → blank or zero"              & LineBreak &
		    LineBreak &
		    "🖼️  Style values:"                                  & LineBreak &
		    "   ARROW     → rising/falling trend line + bracket" & LineBreak &
		    "   TRIANGLE  → solid filled ▲ / ▼"                & LineBreak &
		    LineBreak &
		    "🔄 Direction values (invert up/down):"             & LineBreak &
		    "   INVERSE, INVERT, NEG, LOWER_IS_BETTER"         & LineBreak &
		    "   TRUE, YES, 1"                                   & LineBreak &
		    "   Any other value → normal (positive = up)"       & LineBreak &
		    LineBreak &
		    "📐 SizePx:"                                        & LineBreak &
		    "   Rendered pixel size, e.g. 24, 32, 48, 64"      & LineBreak &
		    "   Aspect ratio always 1:1"                        & LineBreak &
		    "   viewBox fixed at 0 0 48 48"                     & LineBreak &
		    LineBreak &
		    "⚠️  Usage notes:"                                   & LineBreak &
		    "   Set dataCategory = ImageUrl on the measure"     & LineBreak &
		    "   Use in Table / Matrix Image URL field"          & LineBreak &
		    "   Visual row height controls the final size"    & LineBreak &
		    "   Visual row height controls final size"
