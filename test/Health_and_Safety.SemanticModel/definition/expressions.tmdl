expression 'DirectQuery to AS - Global_DatePeriod' =
		let
		    Source = AnalysisServices.Database("powerbi://api.powerbi.com/v1.0/myorg/local-jpa-GlobalDataHouse__WS", "Global_DatePeriod"),
		    Cubes = Table.Combine(Source[Data]),
		    Cube = Cubes{[Id="Model", Kind="Cube"]}[Data]
		in
		    Cube
	lineageTag: c0708b6e-a944-41ea-9466-a3f3909f189a

	annotation PBI_IncludeFutureArtifacts = True

