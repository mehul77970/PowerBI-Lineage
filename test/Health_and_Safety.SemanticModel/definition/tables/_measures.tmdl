	/// Chart-safe TRCF actuals selector for visuals.
	/// 
	/// [Type:  Technical,  Created on: 2026-03-06,  Create by: JPA]
	measure '_TRCF Actuals (Chart Safe)' =
			
			VAR _SelectedCategories =
			    VALUES( dim_workforce_category[workforce_category_ID] )
			VAR _CountSelectedCategories =
			    COUNTROWS( _SelectedCategories )
			
			VAR _WC1Selected =
			    CONTAINSROW( _SelectedCategories, "WC1" )
			
			VAR _IsInvalidWCSelection =
			    _CountSelectedCategories > 1        // multiple categories
			    || ( _WC1Selected && _CountSelectedCategories > 1 ) // WC1 + others
			
			RETURN
			IF(
			    _IsInvalidWCSelection,
			    BLANK(),  // hide actuals
			    SWITCH(
			        TRUE(),
			        SELECTEDVALUE( dim_group[group_ID] ) <> "G0", [TRCF Mgt],
			        SELECTEDVALUE( dim_group[group_ID] ) = "G0", [_TRCF Consolidated (Chart Safe)],
			        BLANK()
			    )
			)
		formatString: 0.00
		displayFolder: technical
		lineageTag: 2eacc71a-1f09-482e-b97c-4b1a1d1c0db1

	/// Chart-safe consolidated TRCF rate for group G0 context.
	/// 
	/// [Type:  Technical,  Created on: 2026-03-06,  Create by: JPA]
	measure '_TRCF Consolidated (Chart Safe)' = ```
			
			
			VAR _worked_hours = [worked hours multiplier]
			
			VAR _injuries =
			   
			        CALCULATE(
			            [Number of Injuries],
			            KEEPFILTERS( dim_workforce_category[workforce_category_ID] = "WC1" ),
			            all( dim_group )
			        )
			
			VAR _hours =
			   
			        CALCULATE(
			            [Number of Worked Hours],
			            KEEPFILTERS( dim_workforce_category[workforce_category_ID] = "WC1" ),
			            all( dim_group ))
			
			
			RETURN
			    DIVIDE( _injuries, _hours, 0 ) * _worked_hours
			```
		formatString: 0.00
		displayFolder: technical
		lineageTag: a7a9b13d-d56f-4fd0-b4eb-6ac533e4a0bd

	/// TRCF target reference line value for chart visuals. Returns the target for the selected group (or G0 when all groups selected), only when workforce category is Employees (WC1). Returns blank for multi-group selections or non-employee categories.
	/// 
	/// [Type: Target, Created on: 2025-03-30, Created by: JPA]
	measure 'TRCF Target Ref' =
			
			VAR _SelectedWorkforceCategory =
			    SELECTEDVALUE( dim_workforce_category[workforce_category_ID] )
			
			VAR _ShowTarget =
			    _SelectedWorkforceCategory = "WC1"
			
			VAR _AllGroupsCount =
			    COUNTROWS( ALL( dim_group[group_ID] ) )
			
			VAR _SelectedGroups =
			    VALUES( dim_group[group_ID] )
			
			VAR _SelectedGroupsCount =
			    COUNTROWS( _SelectedGroups )
			
			VAR _AllGroupsSelected =
			    _SelectedGroupsCount = _AllGroupsCount
			
			VAR _HasSingleGroup =
			    _SelectedGroupsCount = 1
			
			VAR _SelectedGroupID =
			    MAXX( _SelectedGroups, dim_group[group_ID] )
			
			VAR _Result =
			    SWITCH(
			        TRUE(),
			
			        /* All groups selected => force G0 */
			        _AllGroupsSelected,
			            CALCULATE(
			                MAX( 'fct_TRCF_targets'[TRCF_target] ),
			                REMOVEFILTERS( dim_group ),
			                TREATAS( { "G0" }, dim_group[group_ID] )
			            ),
			
			        /* Single group selected => force that group */
			        _HasSingleGroup,
			            CALCULATE(
			                MAX( 'fct_TRCF_targets'[TRCF_target] ),
			                REMOVEFILTERS( dim_group ),
			                TREATAS( { _SelectedGroupID }, dim_group[group_ID] )
			            ),
			
			        BLANK()
			    )
			
			RETURN
			    IF(
			        _ShowTarget,
			        _Result,
			        BLANK()
			    )
		displayFolder: trcf
		lineageTag: 83c34d38-2937-4304-8cdf-9dcf6519115d

