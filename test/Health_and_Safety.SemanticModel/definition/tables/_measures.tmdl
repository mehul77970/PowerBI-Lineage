	/// Percentage of injuries attributed to a specific Life Saving Rule (LSR) or group level, relative to its parent group.
	/// 
	/// [Type:  Percent,  Created on: 2025-09-11,  Create by: JPA]
	measure 'Percent of injuries LSR' =
			
			VAR _currentValue = [Number of Injuries]
			
			-- Identify current group context
			VAR _isLSR =
			    ISINSCOPE( dim_life_saving_rules[life_saving_rules_type] )
			VAR _isLevel2 = ISINSCOPE( dim_group[Level2_group] ) && NOT _isLSR
			
			-- Get current Level2 and Level1 group values
			VAR _currentLevel2 = MAX( dim_group[Level2_group] )
			VAR _currentLevel1 = MAX( dim_group[Level1_group] )
			
			-- Determine parent total depending on context
			VAR _parentTotal =
			    SWITCH(
			        TRUE( ),
			        _isLSR,
			            CALCULATE(
			                [Number of Injuries],
			                REMOVEFILTERS( dim_life_saving_rules ),
			                FILTER(
			                    ALL( dim_group ),
			                    dim_group[Level2_group] = _currentLevel2
			                )
			            ),
			        _isLevel2,
			            CALCULATE(
			                [Number of Injuries],
			                FILTER(
			                    ALL( dim_group ),
			                    dim_group[Level1_group] = _currentLevel1
			                )
			            )
			    )
			RETURN
			    IF(
			        _parentTotal <> 0,
			        DIVIDE( _currentValue, _parentTotal )
			    )
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: lsr
		lineageTag: abeb5465-a3c6-43f7-a8ed-1939a6fa4667

		changedProperty = Name

