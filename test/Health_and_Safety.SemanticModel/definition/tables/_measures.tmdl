	/// TRCF target value based on selected group context.
	/// 
	/// [Type:  Target,  Created on: 2026-03-06,  Create by: JPA]
	measure 'TRCF Target' = ```
			
			 
			VAR _AllGroupsCount =
			    COUNTROWS( ALL( dim_group[group_ID] ) )
			
			VAR _SelectedGroups =
			    VALUES( dim_group[group_ID] )
			
			VAR _SelectedGroupsCount =
			    COUNTROWS( _SelectedGroups )
			
			VAR _AllGroupsSelected =
			    _SelectedGroupsCount = _AllGroupsCount
			
			VAR _HasSingleGroup =
			    _SelectedGroupsCount = 1
			
			VAR _SelectedGroupID =
			    MAXX( _SelectedGroups, dim_group[group_ID] )
			
			VAR _IsAmbiguousSelection =
			    NOT _AllGroupsSelected
			        && NOT _HasSingleGroup
			
			VAR _Result =
			    SWITCH(
			        TRUE(),
			
			        /* All groups selected => force G0 */
			        _AllGroupsSelected,
			            CALCULATE(
			                MAX( 'fct_TRCF_targets'[TRCF_target] ),
			                REMOVEFILTERS( dim_group ),
			                TREATAS( { "G0" }, dim_group[group_ID] )
			            ),
			
			        /* Single group selected => force that group */
			        _HasSingleGroup,
			            CALCULATE(
			                MAX( 'fct_TRCF_targets'[TRCF_target] ),
			                REMOVEFILTERS( dim_group ),
			                TREATAS( { _SelectedGroupID }, dim_group[group_ID] )
			            ),
			
			        BLANK()
			    )
			
			RETURN _Result
			/* IF(
			    _IsAmbiguousSelection,
			    BLANK(),
			    COALESCE( _Result, BLANK() )
			)*/
			```
		displayFolder: trcf
		lineageTag: 991f88da-210b-4726-a821-c96bea8b3e5f

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Difference between TRCF target and actual.
	/// 
	/// [Type:  Delta,  Created on: 2026-03-06,  Create by: JPA]
	measure 'TRCF Delta vs Target' = ```
			
			        VAR _Actual = [TRCF Mgt]
			        VAR _Target = [TRCF Target]
			        RETURN
			            IF(
			                ISBLANK(_Actual) || ISBLANK(_Target),
			                BLANK(),
			                  _Target - _Actual 
			            )
			```
		displayFolder: trcf
		lineageTag: 4b2e72b9-6117-4363-88e6-47e109e8babb

		annotation PBI_FormatHint = {"isGeneralNumber":true}

