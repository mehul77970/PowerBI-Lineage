/// Helper table hosting report-level measures for visuals, percentages, and conditional formatting.
table _measures
	lineageTag: ccccf1e6-c427-4a5f-8aad-20f19811cf6a

	/// Total Recordable Case Frequency (TRCF) by normalizing injury counts against worked hours, and conditionally displays the result only for relevant group levels. Also allows for switch between CSRD and Management
	/// 
	/// [Type: Rate ,  Created on: 2025-09-11,  Create by: JPA]
	measure 'TRCF Mgt' = ```
			
			VAR _worked_hours = [worked hours multiplier]
			
			-- Calculate base inputs
			VAR _injuries = CALCULATE( CALCULATE([Number of Injuries]),KEEPFILTERS( dim_workforce_category[workforce_category_ID] = "WC1" ))
			VAR _hours = CALCULATE( [Number of Worked Hours],KEEPFILTERS( dim_workforce_category[workforce_category_ID] = "WC1" ) )
			
			-- Core TRCF value
			VAR _value = DIVIDE( _injuries, _hours ) * _worked_hours
			
			-- Return 0 if at least one value exists
			VAR _has_data = NOT (
			    ISBLANK(_injuries) &&
			    ISBLANK(_hours)
			)
			
			-- Suppress rows scoped to LSR dimension
			VAR _is_lsr = ISINSCOPE( dim_life_saving_rules[life_saving_rules_type] )
			
			-- Identify total rows and showable levels
			VAR _is_total_row = NOT ISINSCOPE( dim_group[Level1_group] )
			VAR _show_row =
			    ( [BrowseDepth_group] <= [MaxHierarchyDepth_group] || _is_total_row )
			    && NOT _is_lsr
			
			-- Final output
			RETURN
			    IF(
			        _show_row,
			        IF(
			            _has_data,
			            COALESCE(_value, 0),  // return actual value or 0
			            BLANK()               // return blank only if no injuries and no hours
			        )
			    )
			
			```
		displayFolder: trcf
		lineageTag: 949b58c4-1ed8-4f63-be16-ca9dad497c40

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Total PSIF (Potential Serious Injury or Fatality) cases for a comparison period
	/// 
	/// [Type:  Sum,  Created on: 2025-09-11,  Create by: JPA]
	measure 'Total PSIF Comp. period' =
			
			VAR _TotalDates = CALCULATE(COUNTROWS( 'dim_calendar'), ALL(dim_calendar ))
			VAR _SelectedDates = COUNTROWS( dim_calendar )
			VAR _Allselected = _SelectedDates = _TotalDates
			VAR _YearsSelected = DISTINCTCOUNT(dim_calendar[Year])
			VAR _YearRange = MAX(dim_calendar[Year]) - MIN(dim_calendar[Year]) + 1
			VAR _IsContiguous = _YearsSelected = _YearRange
			VAR _Result = IF(_Allselected || NOT _IsContiguous, BLANK(),
			CALCULATE(
			    [PSIF],
			    SAMEPERIODLASTYEAR(dim_calendar[Date])
			))
			RETURN
			    _Result
		formatString: 0
		displayFolder: psif
		lineageTag: 69b2ffa8-6aff-4ec8-9635-c7cf1765921d

	/// Absolute difference (delta) in TRCF (Total Recordable Case Frequency) between the current and comparison periods
	/// 
	/// [Type:  Delta,  Created on: 2025-09-11,  Create by: JPA]
	measure 'TRCF Delta' =
			
			VAR _TotalDates = CALCULATE(COUNTROWS( 'dim_calendar'), ALL(dim_calendar ))
			VAR _SelectedDates = COUNTROWS( dim_calendar )
			VAR _Allselected = _SelectedDates = _TotalDates
			VAR _YearsSelected = DISTINCTCOUNT(dim_calendar[Year])
			VAR _YearRange = MAX(dim_calendar[Year]) - MIN(dim_calendar[Year]) + 1
			VAR _IsContiguous = _YearsSelected = _YearRange
			VAR _CanCompare = NOT _Allselected && _IsContiguous
			VAR _base = [TRCF Mgt]
			VAR _comparison = IF(_CanCompare, CALCULATE([TRCF Mgt], SAMEPERIODLASTYEAR(dim_calendar[Date])))
			VAR _delta = _base - _comparison
			RETURN
			    IF(_CanCompare, _delta, BLANK())
		displayFolder: trcf
		lineageTag: 707277c3-fa1c-4ff7-9f81-e95a82d2588f

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Percentage change in TRCF (Total Recordable Case Frequency) compared to a defined comparison period
	/// 
	/// [Type:  Percent,  Created on: 2025-09-11,  Create by: JPA]
	measure 'TRCF Change' =
			
			VAR _TotalDates = CALCULATE(COUNTROWS( 'dim_calendar'), ALL(dim_calendar ))
			VAR _SelectedDates = COUNTROWS( dim_calendar )
			VAR _Allselected = _SelectedDates = _TotalDates
			VAR _YearsSelected = DISTINCTCOUNT(dim_calendar[Year])
			VAR _YearRange = MAX(dim_calendar[Year]) - MIN(dim_calendar[Year]) + 1
			VAR _IsContiguous = _YearsSelected = _YearRange
			VAR _CanCompare = NOT _Allselected && _IsContiguous
			VAR _base = [TRCF Mgt]
			VAR _comparison = IF(_CanCompare, CALCULATE([TRCF Mgt], SAMEPERIODLASTYEAR(dim_calendar[Date])))
			VAR _percentage =
			    IF(
			        _base = BLANK( ) || 0,
			        BLANK( ),
			        IF(
			            _base <> 0 && _comparison = BLANK( ) || 0,
			            "-",
			            DIVIDE(( _base - _comparison ) , _comparison)
			        )
			    )
			RETURN
			    IF(_CanCompare, _percentage, BLANK())
		formatString: 0.0
		displayFolder: trcf
		lineageTag: 942efb67-4875-46de-ab9e-868dc9aa8f14

