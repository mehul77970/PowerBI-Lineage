	/// Distinct count of recordable injuries that are associated with single Life Saving Rule.
	/// 
	/// [Type:  Count,  Created on: 2025-09-11,  Create by: JPA]
	measure 'Injuries with single LSR' =
			
			VAR _multiple_lsr = [Injuries with multiple LSR]
			VAR _no_lsr = [Injuries with no LSR]
			VAR _injuries = CALCULATE([Total Injuries], dim_life_saving_rules[life_saving_rules_ID] <> { "LSR00"})
			VAR _result = _injuries - _no_lsr - _multiple_lsr
			RETURN
			    _result
		formatString: 0
