	/// Footer text displaying the base period's start and end dates in a MMM yyyy format, providing clear timeframe context when no comparison period is involved.
	/// 
	/// [Type:  Technical,  Created on: 2025-09-11,  Create by: JPA]
	measure '_footer_text_timeframe_no_comp.' =
			
			VAR BaseStart = [DateStart Base]
			VAR BaseEnd = [DateEnd Base]
			RETURN
			    "  Periods between " & FORMAT( BaseStart, "MMM yyyy" )
			        & " - "
			        & FORMAT( BaseEnd, "MMM yyyy" )
		displayFolder: technical
		lineageTag: daad1322-d3d8-4677-98ff-1724736640c4

	/// Conditionally displays the result only for rows within a certain hierarchy depth or total rows—supporting data bar visualizations.
	/// 
	/// [Type:  Technical,  Created on: 2025-09-11,  Create by: JPA]
	measure _databars_TRCF =
			
			VAR _worked_hours = [worked hours multiplier]
			VAR _injuries = CALCULATE( [Number of Injuries] )
			VAR _hours = CALCULATE( [Number of Worked Hours] )
			VAR _value = DIVIDE( _injuries, _hours, 0 ) * _worked_hours
			VAR _is_total_row =
			    ISINSCOPE( dim_group[Level1_group] ) = FALSE
			VAR _show_row =
			    [BrowseDepth_group] <= [MaxHierarchyDepth_group]
			        || _is_total_row
			VAR _result = IF( _show_row, IF( _value <> 0, _value ) )
			RETURN
			    _result
		displayFolder: technical
		lineageTag: 089c4a5f-45ab-44b8-a37b-57f80fe455ea

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Distinct count of recordable injuries that are associated with more than one Life Saving Rule.
	/// 
	/// [Type:  Count,  Created on: 2025-09-11,  Create by: JPA]
	measure 'Injuries with multiple LSR' =
			
			CALCULATE(
			    DISTINCTCOUNT( fct_injuries[recordable_injury_ID] ),
			    FILTER(
			        VALUES( fct_injuries[recordable_injury_ID] ),
			        CALCULATE(
			            DISTINCTCOUNT( fct_injuries[life_saving_rules_ID] )
			        )
			            > 1
			    )
			)
		formatString: 0
		displayFolder: lsr
		lineageTag: f3045e3a-6419-47ee-9700-c8203a2fe73f

	/// Logic based on the ratio of a measure to its maximum value across all groups and countries. It assigns a specific hex color code depending on where the ratio falls within predefined thresholds, enabling dynamic color formatting in visuals.
	/// 
	/// [Type:  Technical,  Created on: 2025-09-11,  Create by: JPA]
	measure _color_gradient_TRCF =
			
			VAR _trcf = [TRCF Mgt]
			VAR _trcf_max =
			    CALCULATE(
			        [TRCF Mgt],
			        REMOVEFILTERS( dim_group ),
			        REMOVEFILTERS( dim_country )
			    )
			VAR _ratio = DIVIDE( _trcf, _trcf_max )
			VAR _result =
			    SWITCH(
			        TRUE( ),
			        ISBLANK( _trcf ), "#6ea6da",
			        _ratio <= 0.1, "#6ba1d8",
			        _ratio <= 0.3, "#6698d5",
			        _ratio <= 0.5, "#6393d3",
			        _ratio <= 0.7, "#6a91cf",
			        _ratio <= 0.9, "#5f7fb8",
			        _ratio <= 1.0, "#657db4",
			        _ratio > 1, "#7683b3"
			    --"#1F4E89"                         -- fallback
			    --7683b3
			    )
			RETURN
			    _result
		displayFolder: technical
		lineageTag: c0bb4e58-370a-4920-a23c-4ed0e7e1156c

		changedProperty = Name

	/// Indicator symbol (up, down, neutral, or blank) based on the percentage change in TRCF (Total Recordable Case Frequency) between the current and comparison periods.
	/// 
	/// [Type:  Technical,  Created on: 2025-09-11,  Create by: JPA]
	measure 'TRCF Change Indicator' =
			
			VAR _TotalDates = CALCULATE(COUNTROWS( 'dim_calendar'), ALL(dim_calendar ))
			VAR _SelectedDates = COUNTROWS( dim_calendar )
			VAR _Allselected = _SelectedDates = _TotalDates
			VAR _YearsSelected = DISTINCTCOUNT(dim_calendar[Year])
			VAR _YearRange = MAX(dim_calendar[Year]) - MIN(dim_calendar[Year]) + 1
			VAR _IsContiguous = _YearsSelected = _YearRange
			VAR _CanCompare = NOT _Allselected && _IsContiguous
			VAR _base = [TRCF Mgt]
			VAR _comparison = IF(_CanCompare, CALCULATE([TRCF Mgt], SAMEPERIODLASTYEAR(dim_calendar[Date])))
			VAR _change = _base - _comparison
			VAR _percentage =
			    IF(
			        _base = BLANK( ) || _base = 0,
			        BLANK( ),
			        IF(
			            _comparison = BLANK( ) || _comparison = 0,
			            "-",
			            DIVIDE(_change , _base)
			        )
			    )
			VAR _indicator = IF(_CanCompare,
			    SWITCH(
			        TRUE( ),
			        ISBLANK( _percentage ), BLANK( ),
			        _percentage = 0, UNICHAR( 9866 ),
			        _percentage < 0, UNICHAR( 9660 ),
			        _percentage > 0, UNICHAR( 9650 ),
			        "-"
			    ), BLANK())
			RETURN
			    _indicator
		displayFolder: trcf
		lineageTag: 57af02e7-51c5-482d-b8d1-ef6371447544

	/// Indicator symbol (up, down, neutral, or blank) based on the percentage change in total injuries between the current and comparison periods.
	/// 
	/// [Type:  Technical  Created on: 2025-09-11,  Create by: JPA]
	measure 'Total Injuries Change Indicator' =
			
			VAR _TotalDates = CALCULATE(COUNTROWS( 'dim_calendar'), ALL(dim_calendar ))
			VAR _SelectedDates = COUNTROWS( dim_calendar )
			VAR _Allselected = _SelectedDates = _TotalDates
			VAR _YearsSelected = DISTINCTCOUNT(dim_calendar[Year])
			VAR _YearRange = MAX(dim_calendar[Year]) - MIN(dim_calendar[Year]) + 1
			VAR _IsContiguous = _YearsSelected = _YearRange
			VAR _CanCompare = NOT _Allselected && _IsContiguous
			VAR _base = [Total Injuries]
			VAR _comparison = IF(_CanCompare, CALCULATE([Total Injuries], SAMEPERIODLASTYEAR(dim_calendar[Date])))
			VAR _change = _base - _comparison
			VAR _percentage =
			    IF(
			        _base = BLANK( ) || _base = 0,
			        BLANK( ),
			        IF(
			            _comparison = BLANK( ) || _comparison = 0,
			            "-",
			            DIVIDE(_change, _base)
			        )
			    )
			VAR _indicator = IF(_CanCompare,
			    SWITCH(
			        TRUE( ),
			        ISBLANK( _percentage ), BLANK( ),
			        _percentage = 0, UNICHAR( 9866 ),
			        _percentage < 0, UNICHAR( 9660 ),
			        _percentage > 0, UNICHAR( 9650 ),
			        "-"
			    ), BLANK())
			RETURN
			    _indicator
		displayFolder: injuries
		lineageTag: 382f2108-083e-42f8-8e26-5ca51309caed

