	/// Displays a warning message when non-contiguous years are selected, informing the user that comparison metrics require consecutive year selections.
	/// 
	/// [Type: Technical, Created on: 2026-04-13, Created by: JPA]
	measure '_Comparison Disclaimer' =
			
			VAR _TotalDates = CALCULATE(COUNTROWS( 'dim_calendar'), ALL(dim_calendar ))
			VAR _SelectedDates = COUNTROWS( dim_calendar )
			VAR _Allselected = _SelectedDates = _TotalDates
			VAR _YearsSelected = DISTINCTCOUNT(dim_calendar[Year])
			VAR _YearRange = MAX(dim_calendar[Year]) - MIN(dim_calendar[Year]) + 1
			VAR _IsContiguous = _YearsSelected = _YearRange
			RETURN
			    IF(
			        _Allselected,
			        BLANK(),
			        IF(
			            NOT _IsContiguous,
			            UNICHAR(9888) & " Comparison requires consecutive year selection",
			            BLANK()
			        )
			    )
		displayFolder: technical
		lineageTag: 1ee862a5-47c5-4c98-a1d9-680b21322938

