	/// Footer text summarizing the selected base and comparison date ranges in a readable format, enhancing clarity in time-based report sections.
	/// 
	/// [Type:  Technical,  Created on: 2025-09-11,  Create by: JPA]
	measure _footer_text_timeframe =
			
			VAR _TotalDates    = CALCULATE( COUNTROWS( 'dim_calendar' ), ALL( 'dim_calendar' ) )
			VAR _SelectedDates = COUNTROWS( 'dim_calendar' )
			VAR _AllSelected   = _SelectedDates = _TotalDates
			VAR _MinDate       = MIN( 'dim_calendar'[Date] )
			VAR _MaxDate       = MAX( 'dim_calendar'[Date] )
			VAR _MinSPLY       = DATE( YEAR( _MinDate ) - 1, MONTH( _MinDate ), DAY( _MinDate ) )
			VAR _MaxSPLY       = DATE( YEAR( _MaxDate ) - 1, MONTH( _MaxDate ), DAY( _MaxDate ) )
			VAR _SameMonth     = MONTH( _MinDate ) = MONTH( _MaxDate ) && YEAR( _MinDate ) = YEAR( _MaxDate )
			VAR _SameYear      = YEAR( _MinDate ) = YEAR( _MaxDate )
			VAR _Current =
			    IF( _SameMonth,
			        FORMAT( _MinDate, "MMM YYYY" ),
			        IF( _SameYear,
			            FORMAT( _MinDate, "MMM" ) & " - " & FORMAT( _MaxDate, "MMM YYYY" ),
			            FORMAT( _MinDate, "MMM YYYY" ) & " - " & FORMAT( _MaxDate, "MMM YYYY" )
			        )
			    )
			VAR _SPLY =
			    IF( _SameMonth,
			        FORMAT( _MinSPLY, "MMM YYYY" ),
			        IF( _SameYear,
			            FORMAT( _MinSPLY, "MMM" ) & " - " & FORMAT( _MaxSPLY, "MMM YYYY" ),
			            FORMAT( _MinSPLY, "MMM YYYY" ) & " - " & FORMAT( _MaxSPLY, "MMM YYYY" )
			        )
			    )
			RETURN
			    IF(
			        _AllSelected,
			        "All periods selected - No Comparison",
			        " Periods between "& _Current & " with Comparison Periods between " & _SPLY
			    )
		displayFolder: technical
		lineageTag: 55a39b74-2dff-46d2-a63e-bd4bb7f9698c

		changedProperty = Name

	/// Dynamic label for injury totals, showing both the filtered and unfiltered values when slicers are applied, enhancing context visibility.
	/// 
	/// [Type:  Technical,  Created on: 2025-09-11,  Create by: JPA]
	measure _label_injury_category =
			
			VAR _filtered_result =
			    CALCULATE(
			        [Total Injuries],
			        ALL( dim_group ),
			        ALL( dim_serious_injury_fatality )
			    )
			
			VAR _base_value =
			    [Total Injuries]
			
			VAR _is_filtered =
			    ISFILTERED( dim_group[Level2_group] )
			        || ISFILTERED( dim_serious_injury_fatality[severe_injury_fatality_type] )
			
			RETURN
			    IF(
			        _is_filtered,
			        _base_value & " / " & _filtered_result,
			        _base_value
			    )
		formatString: 0
		displayFolder: injuries
		lineageTag: fc75745f-ca38-411e-afa8-82e1be1329ec

